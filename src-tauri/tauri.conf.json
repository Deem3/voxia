{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voxia",
  "version": "0.3.0",
  "identifier": "mn.deem.voxia",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "voxia",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$VIDEO/**",
          "$AUDIO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFRUYyMTY5OTAxQTk2NjEKUldSaGxocVFhU0h2M2p3Vm1WQ0dka3BBZmZFRGhMTmY4aS9GUUtEOXBKd3hMZitCRDZYN2tsNGoK",
      "endpoints": [
        "https://github.com/houtarou/voxia/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
