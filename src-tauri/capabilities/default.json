{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window — logic-only build scopes",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "store:default",
    "dialog:default",
    "shell:allow-spawn",
    "log:default",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$APPDATA/**",
        "$DOCUMENT/**",
        "$DOWNLOAD/**",
        "$DESKTOP/**",
        "$VIDEO/**",
        "$AUDIO/**",
        "$RESOURCE/**"
      ]
    }
  ]
}
